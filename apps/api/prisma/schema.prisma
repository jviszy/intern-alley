generator client {
provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
INTERN
COMPANY_ADMIN
}

enum JobStatus {
DRAFT
OPEN
CLOSED
}

enum JobType {
INTERNSHIP
SIWES
NYSC
GRADUATE_TRAINEE
PART_TIME
}

enum WorkMode {
ONSITE
REMOTE
HYBRID
}

enum ApplicationStatus {
SUBMITTED
REVIEWING
ACCEPTED
REJECTED
WITHDRAWN
}

model User {
id           String   @id @default(uuid())
email        String   @unique
passwordHash String
role         UserRole
createdAt    DateTime @default(now())
updatedAt    DateTime @updatedAt

internProfile InternProfile?
company       Company?

@@index([role])
}

model InternProfile {
id                 String   @id @default(uuid())
userId             String   @unique
firstName          String
lastName           String
phone              String?
location           String?
bio                String?
school             String?
course             String?
graduationYear     Int?
skills             String[]
preferredLocations String[]
preferredJobTypes  JobType[]
resumeUrl          String?
createdAt          DateTime @default(now())
updatedAt          DateTime @updatedAt

user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
applications Application[]

@@index([location])
@@index([graduationYear])
}

model Company {
id          String   @id @default(uuid())
ownerUserId String   @unique
name        String
description String?
website     String?
industry    String?
location    String?
logoUrl     String?
createdAt   DateTime @default(now())
updatedAt   DateTime @updatedAt

owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
jobs  Job[]

@@index([industry])
@@index([location])
}

model Job {
id             String    @id @default(uuid())
companyId      String
title          String
description    String
location       String
jobType        JobType
workMode       WorkMode
requiredSkills String[]
salaryMin      Int?
salaryMax      Int?
deadline       DateTime?
status         JobStatus @default(DRAFT)
createdAt      DateTime  @default(now())
updatedAt      DateTime  @updatedAt

company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
applications Application[]

@@index([companyId])
@@index([status])
@@index([location])
@@index([jobType])
@@index([workMode])
@@index([createdAt])
}

model Application {
id          String            @id @default(uuid())
jobId       String
internId    String
coverLetter String?
status      ApplicationStatus @default(SUBMITTED)
createdAt   DateTime          @default(now())
updatedAt   DateTime          @updatedAt

job    Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
intern InternProfile @relation(fields: [internId], references: [id], onDelete: Cascade)

@@unique([jobId, internId])
@@index([jobId])
@@index([internId])
@@index([status])
}
